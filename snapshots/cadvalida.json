    "Validar": "\tIF EMPTY(ThisForm.nome)\n\t\tRETURN \"nome: obrigatorio\"\n\tENDIF\n\tIF LEN(ALLTRIM(ThisForm.nome)) < 3\n\t\tRETURN \"nome: minimo 3 caracteres\"\n\tENDIF\n\tIF LEN(ALLTRIM(ThisForm.nome)) > 10\n\t\tRETURN \"nome: maximo 10 caracteres\"\n\tENDIF\n\tIF LEN(ALLTRIM(ThisForm.uf)) <> 2\n\t\tRETURN \"uf: deve ter 2 caracteres\"\n\tENDIF\n\tIF ThisForm.idade < 18\n\t\tRETURN \"idade: minimo 18\"\n\tENDIF\n\tIF ThisForm.idade > 120\n\t\tRETURN \"idade: maximo 120\"\n\tENDIF\n\tRETURN \"\""
