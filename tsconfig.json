{
  // FONTE ÚNICA destas opções. O build (loadProgram em transpile.js) LE este
  // arquivo via ts.parseJsonConfigFileContent; o EDITOR (IntelliSense, JSX,
  // decorators, @vfp/core) e `npx tsc --noEmit -p .` usam o mesmo. O build apenas
  // sobrepõe noEmit/module/moduleResolution por código. Edite aqui, nao no .js.
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "experimentalDecorators": true,
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["es2020"],
    "jsx": "preserve",
    "baseUrl": ".",
    "paths": { "@vfp/core": ["decorators"] },
    "types": []
  },
  "include": [
    "globals.d.ts",
    "decorators.ts",
    "fox.ts",
    "db.ts",
    "examples/**/*",
    "showcase/**/*"
  ]
}
