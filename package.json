{
  "name": "foxts",
  "version": "0.1.0",
  "description": "Transpilador de um subconjunto tipado de TypeScript para Visual FoxPro 9 (PRG/SCX). Compila em build-time; nao ha runtime JS no app gerado.",
  "type": "commonjs",
  "license": "MIT",
  "author": "Igor Leonardo <igor.leonardo@pwi.com.br>",
  "homepage": "https://github.com/IgorLAO/foxts#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IgorLAO/foxts.git"
  },
  "bugs": {
    "url": "https://github.com/IgorLAO/foxts/issues"
  },
  "keywords": [
    "foxpro",
    "visual-foxpro",
    "vfp",
    "vfp9",
    "transpiler",
    "typescript",
    "prg",
    "scx",
    "codegen",
    "compiler"
  ],
  "main": "transpile.js",
  "bin": {
    "foxts": "cli.js",
    "foxc": "foxc.js",
    "vfp": "vfp.js"
  },
  "files": [
    "cli.js",
    "foxc.js",
    "vfp.js",
    "transpile.js",
    "layout.js",
    "foxcli-path.js",
    "decorators.ts",
    "globals.d.ts",
    "fox.ts",
    "db.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "node build.js",
    "build:calc": "node cli.js examples/calc.ts -o dist/calc.prg",
    "foxcli": "node foxcli.js",
    "foxcli:build": "go build -C foxcli -o foxcli.exe .",
    "verify": "node verify.js",
    "verify:cursor": "node verifycursor.js",
    "verify:sql": "node verifysql.js",
    "verify:class": "node verifyclass.js",
    "verify:query": "node verifyquery.js",
    "verify:route": "node verifyroute.js",
    "verify:validate": "node verifyvalidate.js",
    "verify:layout": "node verifylayout.js",
    "lint": "node lint.js src examples",
    "test": "node test.js",
    "build:form": "node foxc.js build examples/dias.form.ts -o dist/frmdiasts.scx"
  },
  "dependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "typescript": "^5.6.0",
    "yoga-layout": "^3.2.1"
  }
}
