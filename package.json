{
  "name": "foxts",
  "version": "0.1.0",
  "private": true,
  "description": "Transpilador de um subconjunto tipado de TypeScript para Visual FoxPro 9 (PRG). Compila em build-time; nao ha runtime JS no app gerado.",
  "type": "commonjs",
  "bin": {
    "foxts": "cli.js",
    "vfp": "vfp.js"
  },
  "scripts": {
    "build": "node cli.js examples/calc.ts -o dist/calc.prg",
    "verify": "node verify.js",
    "verify:cursor": "node verifycursor.js",
    "verify:sql": "node verifysql.js",
    "verify:class": "node verifyclass.js",
    "verify:query": "node verifyquery.js",
    "verify:route": "node verifyroute.js",
    "verify:validate": "node verifyvalidate.js",
    "verify:layout": "node verifylayout.js",
    "lint": "node lint.js src examples",
    "test": "node test.js",
    "build:form": "node foxc.js build examples/dias.form.ts -o dist/frmdiasts.scx"
  },
  "dependencies": {
    "typescript": "^5.6.0",
    "yoga-layout": "^3.2.1"
  }
}
